{
  "name": "plugsky",
  "version": "0.2.0",
  "description": "Plugsky CLI — a premium agentic AI coding assistant for your terminal.",
  "type": "module",
  "bin": {
    "plugsky": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "oxlint src",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.0",
    "picomatch": "^4.0.2",
    "react": "^18.3.1",
    "react-devtools-core": "7.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/react": "^18.3.3",
    "bun-types": "1.3.14",
    "oxlint": "^0.9.0",
    "typescript": "^5.5.4"
  }
}
